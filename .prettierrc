{
  "semi": false,
  "tabWidth": 2,
  "printWidth": 100,
  "useTabs": false,
  "quoteProps": "as-needed",
  "singleQuote": true,
  "trailingComma": "all",
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "arrowParens": "always",
  "overrides": [
    {
      "files": ["*.json"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}
